APP_NAME=market-river-generator
AWS_REGION=us-west-2
S3_BUCKET=stethem-market-river-dev
PUBLIC_BASE_URL=
IMAGE_PROVIDER=mock
FAL_MODEL=fal-ai/flux/schnell
FAL_IMAGE_SIZE=landscape_4_3
